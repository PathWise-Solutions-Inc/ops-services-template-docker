# Ops Services Template Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env file to version control

# ============================================
# PostgreSQL Configuration
# ============================================
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_USER=postgres
POSTGRES_DB=postgres

# ============================================
# Supabase Configuration
# ============================================
# Generate JWT secret: openssl rand -hex 32
SUPABASE_JWT_SECRET=your_jwt_secret_at_least_32_characters_long_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_PUBLIC_URL=http://localhost:8000
DEFAULT_ORGANIZATION_NAME=Your Organization
DEFAULT_PROJECT_NAME=Ops Services
PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_ANON_ROLE=anon
PGRST_JWT_EXP=3600

# ============================================
# n8n Configuration
# ============================================
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_n8n_password_here
# Generate encryption key: openssl rand -hex 32
N8N_ENCRYPTION_KEY=your_n8n_encryption_key_here
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_METRICS=true

# ============================================
# LightRAG Configuration
# ============================================
LIGHTRAG_STORAGE_TYPE=postgres
LIGHTRAG_DB_URL=postgresql://postgres:your_postgres_password_here@postgres:5432/lightrag
LIGHTRAG_API_KEY=your_lightrag_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
LIGHTRAG_LOG_LEVEL=INFO

# ============================================
# Redis Configuration
# ============================================
REDIS_PASSWORD=your_redis_password_here

# ============================================
# API Gateway Configuration
# ============================================
API_GATEWAY_DOMAIN=localhost
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# ============================================
# Monitoring Configuration
# ============================================
MONITORING_ADMIN_PASSWORD=your_grafana_admin_password_here

# ============================================
# Development Settings (override in .env.local)
# ============================================
NODE_ENV=production
LOG_LEVEL=info